# MotherDuck — cloud DuckDB (obter em app.motherduck.com → Settings → Token)
# Quando presente, dados são salvos/lidos no MotherDuck em vez do arquivo local.
MOTHERDUCK_TOKEN=

# Cloudflare R2 — upload de parquets (opcional)
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# MercadoLivre Developers — coleta de imóveis (E2 property_inventory)
# Obter em developers.mercadolivre.com.br → Criar aplicação
ML_APP_ID=
ML_SECRET=

# Diretório de dados local (padrão: data/)
# RESEARCH_LAB_DATA_DIR=data
